const factorial = (n: number) => {
>factorial : Symbol(factorial, Decl(customIntrinsics.ts, 102, 5))
>n : Symbol(n, Decl(customIntrinsics.ts, 102, 19))

    let result: number = 1;
>result : Symbol(result, Decl(customIntrinsics.ts, 103, 7))

    let i: number = n;
>i : Symbol(i, Decl(customIntrinsics.ts, 104, 7))
>n : Symbol(n, Decl(customIntrinsics.ts, 102, 19))

    while (i > 0) { result = result * i; i = i - 1; }
>i : Symbol(i, Decl(customIntrinsics.ts, 104, 7))
>result : Symbol(result, Decl(customIntrinsics.ts, 103, 7))
>result : Symbol(result, Decl(customIntrinsics.ts, 103, 7))
>i : Symbol(i, Decl(customIntrinsics.ts, 104, 7))
>i : Symbol(i, Decl(customIntrinsics.ts, 104, 7))
>i : Symbol(i, Decl(customIntrinsics.ts, 104, 7))

    return result;
>result : Symbol(result, Decl(customIntrinsics.ts, 103, 7))

};

