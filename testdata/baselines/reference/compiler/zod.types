>_nonnegative : (n: any) => number | undefined

export type ZPort<T> = Intrinsic<typeof _port, [T]>;
>ZPort : intrinsic
>_port : (n: any) => number | undefined

export type ZCoerceNumber<T> = Intrinsic<typeof _coerceNumber, [T]>;
