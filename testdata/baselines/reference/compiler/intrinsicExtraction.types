=== extraction.ts ===
// Multiline function body
const multiline = (n: number) => {
>multiline : (n: number) => number
>(n: number) => {    let x: number = n        + 1;    let y: number = x        * 2;    return y;} : (n: number) => number
>n : number

    let x: number = n
>x : number
>n        + 1 : number
>n : number

        + 1;
>1 : 1

    let y: number = x
>y : number
>x        * 2 : number
>x : number

        * 2;
>2 : 2

    return y;
>y : number

};
type EX1 = Intrinsic<typeof multiline, [5]>;  // 12
>EX1 : 12
>multiline : (n: number) => number

// Type annotations on parameters and locals
