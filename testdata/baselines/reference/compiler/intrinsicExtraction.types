>(    s: string,    n: number,    flag: boolean) => {    let result: string = s;    let count: number = n;    if (flag) return result + count;    return result;} : (s: string, n: number, flag: boolean) => string

    s: string,
>s : string

    n: number,
>n : number

    flag: boolean
>flag : boolean

) => {
    let result: string = s;
>result : string
>s : string

    let count: number = n;
>count : number
>n : number

    if (flag) return result + count;
>flag : boolean
>result + count : string
>result : string
>count : number

    return result;
>result : string

};
type EX2 = Intrinsic<typeof annotated, ["x", 3, true]>;  // "x3"
>EX2 : "x3"
>annotated : (s: string, n: number, flag: boolean) => string
>true : true

type EX3 = Intrinsic<typeof annotated, ["x", 3, false]>; // "x"
>EX3 : "x"
>annotated : (s: string, n: number, flag: boolean) => string
>false : false

