// budget exceeded: infinite loop
const infinite = (n: number) => {
>infinite : Symbol(infinite, Decl(intrinsicErrors.ts, 50, 5))
>n : Symbol(n, Decl(intrinsicErrors.ts, 50, 18))

    let i: number = 0;
>i : Symbol(i, Decl(intrinsicErrors.ts, 51, 7))

    while (i < n) { i = i + 1; }
>i : Symbol(i, Decl(intrinsicErrors.ts, 51, 7))
>n : Symbol(n, Decl(intrinsicErrors.ts, 50, 18))
>i : Symbol(i, Decl(intrinsicErrors.ts, 51, 7))
>i : Symbol(i, Decl(intrinsicErrors.ts, 51, 7))

    return i;
>i : Symbol(i, Decl(intrinsicErrors.ts, 51, 7))

};
