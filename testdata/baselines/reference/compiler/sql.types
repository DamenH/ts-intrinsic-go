// Collapse runs of whitespace to a single space, preserving single-quoted strings.
export const normalizeSql = (sql: string) => {
>normalizeSql : (sql: string) => string
>(sql: string) => {    let norm: string = '';    let lastWasSpace: boolean = true;    let inStr: boolean = false;    let i = 0;    while (i < sql.length) {        let c: string = sql.slice(i, i + 1);        if (c == "'") { inStr = !inStr; norm = norm + c; lastWasSpace = false; }        else if (inStr) { norm = norm + c; lastWasSpace = false; }        else if (c == ' ' || c == '\n' || c == '\t') {            if (!lastWasSpace) { norm = norm + ' '; lastWasSpace = true; }        } else { norm = norm + c; lastWasSpace = false; }        i = i + 1;    }    return norm.trim();} : (sql: string) => string
