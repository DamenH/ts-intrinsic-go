=== sql_test.ts ===
import { Sql, TypedQuery } from "./sql";
>Sql : any
>TypedQuery : any

// ==== SELECT: structured breakdown ====

type S01 = Sql<"SELECT * FROM users">;
>S01 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: []; }

type S02 = Sql<"SELECT name, age FROM users">;
>S02 : { statement: "SELECT"; table: "users"; columns: ["name", "age"]; params: []; }

type S03 = Sql<"SELECT name FROM users WHERE id = 1">;
>S03 : { statement: "SELECT"; table: "users"; columns: ["name"]; params: []; where: "id = 1"; }

type S04 = Sql<"SELECT * FROM users ORDER BY name ASC">;
>S04 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: []; orderBy: "name ASC"; }

type S05 = Sql<"SELECT * FROM users WHERE active = 1 LIMIT 10">;
>S05 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: []; where: "active = 1"; limit: "10"; }

type S06 = Sql<"SELECT * FROM users WHERE id = $1">;
>S06 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: ["$1"]; where: "id = $1"; }

type S07 = Sql<"SELECT * FROM users WHERE id = $1 AND status = $2">;
>S07 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: ["$1", "$2"]; where: "id = $1 AND status = $2"; }

// ==== INSERT ====

type I01 = Sql<"INSERT INTO users VALUES ($1, $2, $3)">;
>I01 : { statement: "INSERT"; table: "users"; params: ["$1", "$2", "$3"]; }

type I02 = Sql<"INSERT INTO users (name, age) VALUES ($1, $2)">;
>I02 : { statement: "INSERT"; table: "users"; columns: ["name", "age"]; params: ["$1", "$2"]; }

// ==== UPDATE ====

type U01 = Sql<"UPDATE users SET name = $1 WHERE id = $2">;
>U01 : { statement: "UPDATE"; table: "users"; set: ["name = $1"]; params: ["$1", "$2"]; where: "id = $2"; }

type U02 = Sql<"UPDATE users SET active = 0">;
>U02 : { statement: "UPDATE"; table: "users"; set: ["active = 0"]; params: []; }

// ==== DELETE ====

type D01 = Sql<"DELETE FROM users WHERE id = $1">;
>D01 : { statement: "DELETE"; table: "users"; params: ["$1"]; where: "id = $1"; }

type D02 = Sql<"DELETE FROM sessions">;
>D02 : { statement: "DELETE"; table: "sessions"; params: []; }

// ==== CREATE TABLE ====

type C01 = Sql<"CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT NOT NULL, age INTEGER)">;
>C01 : { statement: "CREATE TABLE"; table: "users"; definition: "id INTEGER PRIMARY KEY, name TEXT NOT NULL, age INTEGER"; }

// ==== Errors produce descriptive messages ====

type E01 = Sql<"">;                            // "Error: empty query"
>E01 : "Error: empty query"

type E02 = Sql<"SELCT * FROM users">;          // "Error: unsupported statement ..."
>E02 : "Error: unsupported statement (expected SELECT, INSERT, UPDATE, DELETE, or CREATE TABLE)"

type E03 = Sql<"SELECT FROM users">;           // "Error: SELECT requires column list"
>E03 : "Error: SELECT requires column list"

type E04 = Sql<"SELECT *">;                    // "Error: SELECT requires FROM clause"
>E04 : "Error: SELECT requires FROM clause"

type E05 = Sql<"SELECT * FROM">;               // "Error: FROM requires table name"
>E05 : "Error: FROM requires table name"

type E06 = Sql<"INSERT INTO users">;           // "Error: INSERT requires VALUES clause"
>E06 : "Error: INSERT requires VALUES clause"

type E07 = Sql<"UPDATE users WHERE id = 1">;   // "Error: UPDATE requires SET clause"
>E07 : "Error: UPDATE requires SET clause"

type E08 = Sql<"DROP TABLE users">;            // "Error: unsupported statement ..."
>E08 : "Error: unsupported statement (expected SELECT, INSERT, UPDATE, DELETE, or CREATE TABLE)"

// ==== Complex queries ====

type CQ1 = Sql<"SELECT * FROM users WHERE id IN (SELECT user_id FROM orders)">;
>CQ1 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: []; where: "id IN (SELECT user_id FROM orders)"; }

type CQ2 = Sql<"SELECT u.name, o.total FROM users u LEFT JOIN orders o ON u.id = o.user_id">;
>CQ2 : { statement: "SELECT"; table: "users"; columns: ["u.name", "o.total"]; params: []; }

type CQ3 = Sql<"SELECT * FROM users WHERE age BETWEEN 18 AND 65">;
>CQ3 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: []; where: "age BETWEEN 18 AND 65"; }

type CQ4 = Sql<"SELECT * FROM users WHERE status IS NOT NULL ORDER BY created_at DESC LIMIT 20">;
>CQ4 : { statement: "SELECT"; table: "users"; columns: ["*"]; params: []; where: "status IS NOT NULL"; orderBy: "created_at DESC"; limit: "20"; }

type CQ5 = Sql<"SELECT name FROM users WHERE email LIKE '%@example.com'">;
>CQ5 : { statement: "SELECT"; table: "users"; columns: ["name"]; params: []; where: "email LIKE '%@example.com'"; }

type CQ6 = Sql<"UPDATE products SET price = price * 1.1, updated_at = $1 WHERE category = $2">;
>CQ6 : { statement: "UPDATE"; table: "products"; set: ["price = price * 1.1", "updated_at = $1"]; params: ["$1", "$2"]; where: "category = $2"; }

type CQ7 = Sql<"DELETE FROM sessions WHERE expires_at < $1 AND user_id IS NOT NULL">;
>CQ7 : { statement: "DELETE"; table: "sessions"; params: ["$1"]; where: "expires_at < $1 AND user_id IS NOT NULL"; }

type CQ8 = Sql<"INSERT INTO order_items (order_id, product_id, qty) VALUES ($1, $2, $3)">;
>CQ8 : { statement: "INSERT"; table: "order_items"; columns: ["order_id", "product_id", "qty"]; params: ["$1", "$2", "$3"]; }


// ==== Schema-aware validation using CREATE TABLE statements ====

const db = `
>db : "\nCREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT, age INTEGER, active BOOLEAN);\nCREATE TABLE posts (id INTEGER PRIMARY KEY, title TEXT, body TEXT, user_id INTEGER, published BOOLEAN);\nCREATE TABLE orders (id INTEGER PRIMARY KEY, user_id INTEGER, total REAL, status TEXT);\n"
>`CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT, age INTEGER, active BOOLEAN);CREATE TABLE posts (id INTEGER PRIMARY KEY, title TEXT, body TEXT, user_id INTEGER, published BOOLEAN);CREATE TABLE orders (id INTEGER PRIMARY KEY, user_id INTEGER, total REAL, status TEXT);` as const : "\nCREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT, age INTEGER, active BOOLEAN);\nCREATE TABLE posts (id INTEGER PRIMARY KEY, title TEXT, body TEXT, user_id INTEGER, published BOOLEAN);\nCREATE TABLE orders (id INTEGER PRIMARY KEY, user_id INTEGER, total REAL, status TEXT);\n"
>`CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT, age INTEGER, active BOOLEAN);CREATE TABLE posts (id INTEGER PRIMARY KEY, title TEXT, body TEXT, user_id INTEGER, published BOOLEAN);CREATE TABLE orders (id INTEGER PRIMARY KEY, user_id INTEGER, total REAL, status TEXT);` : "\nCREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT, age INTEGER, active BOOLEAN);\nCREATE TABLE posts (id INTEGER PRIMARY KEY, title TEXT, body TEXT, user_id INTEGER, published BOOLEAN);\nCREATE TABLE orders (id INTEGER PRIMARY KEY, user_id INTEGER, total REAL, status TEXT);\n"

CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT, age INTEGER, active BOOLEAN);
CREATE TABLE posts (id INTEGER PRIMARY KEY, title TEXT, body TEXT, user_id INTEGER, published BOOLEAN);
CREATE TABLE orders (id INTEGER PRIMARY KEY, user_id INTEGER, total REAL, status TEXT);
` as const;

