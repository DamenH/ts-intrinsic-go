// --- Deeply nested closures ---

const nestedClosures = (n: number) => {
>nestedClosures : Symbol(nestedClosures, Decl(intrinsicEdgeCases.ts, 18, 5))
>n : Symbol(n, Decl(intrinsicEdgeCases.ts, 18, 24))

    let a = (x: number) => {
>a : Symbol(a, Decl(intrinsicEdgeCases.ts, 19, 7))
>x : Symbol(x, Decl(intrinsicEdgeCases.ts, 19, 13))

        let b = (y: number) => {
>b : Symbol(b, Decl(intrinsicEdgeCases.ts, 20, 11))
>y : Symbol(y, Decl(intrinsicEdgeCases.ts, 20, 17))

            let c = (z: number) => {
>c : Symbol(c, Decl(intrinsicEdgeCases.ts, 21, 15))
>z : Symbol(z, Decl(intrinsicEdgeCases.ts, 21, 21))

                let d = (w: number) => w + z + y + x;
>d : Symbol(d, Decl(intrinsicEdgeCases.ts, 22, 19))
>w : Symbol(w, Decl(intrinsicEdgeCases.ts, 22, 25))
>w : Symbol(w, Decl(intrinsicEdgeCases.ts, 22, 25))
>z : Symbol(z, Decl(intrinsicEdgeCases.ts, 21, 21))
>y : Symbol(y, Decl(intrinsicEdgeCases.ts, 20, 17))
>x : Symbol(x, Decl(intrinsicEdgeCases.ts, 19, 13))

                return d(1);
>d : Symbol(d, Decl(intrinsicEdgeCases.ts, 22, 19))

            };
            return c(2);
>c : Symbol(c, Decl(intrinsicEdgeCases.ts, 21, 15))

        };
        return b(3);
>b : Symbol(b, Decl(intrinsicEdgeCases.ts, 20, 11))

    };
    return a(n);
>a : Symbol(a, Decl(intrinsicEdgeCases.ts, 19, 7))
>n : Symbol(n, Decl(intrinsicEdgeCases.ts, 18, 24))

};
type NC1 = Intrinsic<typeof nestedClosures, [10]>;  // 10 + 3 + 2 + 1 = 16
>NC1 : Symbol(NC1, Decl(intrinsicEdgeCases.ts, 30, 2))
>Intrinsic : Symbol(Intrinsic, Decl(lib.es5.d.ts, --, --))
>nestedClosures : Symbol(nestedClosures, Decl(intrinsicEdgeCases.ts, 18, 5))

// Closure that builds and calls functions in a loop
const closureLoop = (n: number) => {
>closureLoop : Symbol(closureLoop, Decl(intrinsicEdgeCases.ts, 34, 5))
>n : Symbol(n, Decl(intrinsicEdgeCases.ts, 34, 21))

    let result: number = 0;
>result : Symbol(result, Decl(intrinsicEdgeCases.ts, 35, 7))

    let i: number = 0;
>i : Symbol(i, Decl(intrinsicEdgeCases.ts, 36, 7))

    while (i < n) {
>i : Symbol(i, Decl(intrinsicEdgeCases.ts, 36, 7))
>n : Symbol(n, Decl(intrinsicEdgeCases.ts, 34, 21))

        let captured: number = i;
>captured : Symbol(captured, Decl(intrinsicEdgeCases.ts, 38, 11))
>i : Symbol(i, Decl(intrinsicEdgeCases.ts, 36, 7))

        let f = (x: number) => x + captured;
>f : Symbol(f, Decl(intrinsicEdgeCases.ts, 39, 11))
>x : Symbol(x, Decl(intrinsicEdgeCases.ts, 39, 17))
>x : Symbol(x, Decl(intrinsicEdgeCases.ts, 39, 17))
>captured : Symbol(captured, Decl(intrinsicEdgeCases.ts, 38, 11))

        result = f(result);
>result : Symbol(result, Decl(intrinsicEdgeCases.ts, 35, 7))
>f : Symbol(f, Decl(intrinsicEdgeCases.ts, 39, 11))
>result : Symbol(result, Decl(intrinsicEdgeCases.ts, 35, 7))

        i = i + 1;
>i : Symbol(i, Decl(intrinsicEdgeCases.ts, 36, 7))
>i : Symbol(i, Decl(intrinsicEdgeCases.ts, 36, 7))
    }
    return result;
>result : Symbol(result, Decl(intrinsicEdgeCases.ts, 35, 7))

};
type NC2 = Intrinsic<typeof closureLoop, [10]>;  // 0+0+1+2+...+9 = 45
>NC2 : Symbol(NC2, Decl(intrinsicEdgeCases.ts, 44, 2))
>Intrinsic : Symbol(Intrinsic, Decl(lib.es5.d.ts, --, --))
>closureLoop : Symbol(closureLoop, Decl(intrinsicEdgeCases.ts, 34, 5))


