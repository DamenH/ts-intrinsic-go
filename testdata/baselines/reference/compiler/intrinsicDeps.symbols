// Object return
const makePoint = (x: number, y: number) => {
>makePoint : Symbol(makePoint, Decl(intrinsicDeps.ts, 36, 5))
>x : Symbol(x, Decl(intrinsicDeps.ts, 36, 19))
>y : Symbol(y, Decl(intrinsicDeps.ts, 36, 29))

    let result: Record<string, any> = {};
>result : Symbol(result, Decl(intrinsicDeps.ts, 37, 7))
>Record : Symbol(Record, Decl(lib.es5.d.ts, --, --))

    result["x"] = x;
>result : Symbol(result, Decl(intrinsicDeps.ts, 37, 7))
>x : Symbol(x, Decl(intrinsicDeps.ts, 36, 19))

    result["y"] = y;
>result : Symbol(result, Decl(intrinsicDeps.ts, 37, 7))
>y : Symbol(y, Decl(intrinsicDeps.ts, 36, 29))

    return result;
>result : Symbol(result, Decl(intrinsicDeps.ts, 37, 7))

};
const shiftPoint = (x: number, y: number, dx: number, dy: number) => makePoint(x + dx, y + dy);
