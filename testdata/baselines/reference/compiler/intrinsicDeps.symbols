>n : Symbol(n, Decl(intrinsicDeps.ts, 7, 14))
>n : Symbol(n, Decl(intrinsicDeps.ts, 7, 14))

const add2 = (n: number) => add1(add1(n));
>add2 : Symbol(add2, Decl(intrinsicDeps.ts, 8, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 8, 14))
>add1 : Symbol(add1, Decl(intrinsicDeps.ts, 7, 5))
>add1 : Symbol(add1, Decl(intrinsicDeps.ts, 7, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 8, 14))

const add4 = (n: number) => add2(add2(n));
>add4 : Symbol(add4, Decl(intrinsicDeps.ts, 9, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 9, 14))
>add2 : Symbol(add2, Decl(intrinsicDeps.ts, 8, 5))
>add2 : Symbol(add2, Decl(intrinsicDeps.ts, 8, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 9, 14))

