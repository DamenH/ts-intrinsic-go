>dx : Symbol(dx, Decl(intrinsicDeps.ts, 42, 41))
>y : Symbol(y, Decl(intrinsicDeps.ts, 42, 30))
>dy : Symbol(dy, Decl(intrinsicDeps.ts, 42, 53))

