// Diamond: combined -> doubleInc -> inc, combined -> tripleInc -> inc
const inc = (n: number) => n + 1;
>inc : Symbol(inc, Decl(intrinsicDeps.ts, 46, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 46, 13))
>n : Symbol(n, Decl(intrinsicDeps.ts, 46, 13))

const doubleInc = (n: number) => inc(n) * 2;
>doubleInc : Symbol(doubleInc, Decl(intrinsicDeps.ts, 47, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 47, 19))
>inc : Symbol(inc, Decl(intrinsicDeps.ts, 46, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 47, 19))

const tripleInc = (n: number) => inc(n) * 3;
>tripleInc : Symbol(tripleInc, Decl(intrinsicDeps.ts, 48, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 48, 19))
>inc : Symbol(inc, Decl(intrinsicDeps.ts, 46, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 48, 19))

const combined = (n: number) => doubleInc(n) + tripleInc(n);
>combined : Symbol(combined, Decl(intrinsicDeps.ts, 49, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 49, 18))
>doubleInc : Symbol(doubleInc, Decl(intrinsicDeps.ts, 47, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 49, 18))
>tripleInc : Symbol(tripleInc, Decl(intrinsicDeps.ts, 48, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 49, 18))

type D9 = Intrinsic<typeof combined, [4]>;  // 10 + 15 = 25
>D9 : Symbol(D9, Decl(intrinsicDeps.ts, 49, 60))
>Intrinsic : Symbol(Intrinsic, Decl(lib.es5.d.ts, --, --))
>combined : Symbol(combined, Decl(intrinsicDeps.ts, 49, 5))

// Helper calling helper
const capitalize = (s: string) => {
>capitalize : Symbol(capitalize, Decl(intrinsicDeps.ts, 53, 5))
>s : Symbol(s, Decl(intrinsicDeps.ts, 53, 20))

    if (s.length == 0) return s;
>s.length : Symbol(String.length, Decl(lib.es5.d.ts, --, --))
>s : Symbol(s, Decl(intrinsicDeps.ts, 53, 20))
>length : Symbol(String.length, Decl(lib.es5.d.ts, --, --))
>s : Symbol(s, Decl(intrinsicDeps.ts, 53, 20))

    return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();
>s.charAt(0).toUpperCase : Symbol(String.toUpperCase, Decl(lib.es5.d.ts, --, --))
>s.charAt : Symbol(String.charAt, Decl(lib.es5.d.ts, --, --))
>s : Symbol(s, Decl(intrinsicDeps.ts, 53, 20))
>charAt : Symbol(String.charAt, Decl(lib.es5.d.ts, --, --))
>toUpperCase : Symbol(String.toUpperCase, Decl(lib.es5.d.ts, --, --))
>s.slice(1).toLowerCase : Symbol(String.toLowerCase, Decl(lib.es5.d.ts, --, --))
>s.slice : Symbol(String.slice, Decl(lib.es5.d.ts, --, --))
>s : Symbol(s, Decl(intrinsicDeps.ts, 53, 20))
>slice : Symbol(String.slice, Decl(lib.es5.d.ts, --, --))
>toLowerCase : Symbol(String.toLowerCase, Decl(lib.es5.d.ts, --, --))

};
const titleCase = (s: string) => s.split(" ").map((w: string) => capitalize(w)).join(" ");
