const withBlockComments = (n: number) => {
>withBlockComments : Symbol(withBlockComments, Decl(intrinsicDeps.ts, 69, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 69, 27))

    let x: number = n /* input */ + 1;
>x : Symbol(x, Decl(intrinsicDeps.ts, 70, 7))
>n : Symbol(n, Decl(intrinsicDeps.ts, 69, 27))

    /* square */
    return x * x;
>x : Symbol(x, Decl(intrinsicDeps.ts, 70, 7))
>x : Symbol(x, Decl(intrinsicDeps.ts, 70, 7))

};
