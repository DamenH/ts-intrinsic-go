// Comments in function bodies
const withLineComments = (n: number) => {
>withLineComments : Symbol(withLineComments, Decl(intrinsicDeps.ts, 61, 5))
>n : Symbol(n, Decl(intrinsicDeps.ts, 61, 26))

    // double it
    let x: number = n * 2;
>x : Symbol(x, Decl(intrinsicDeps.ts, 63, 7))
>n : Symbol(n, Decl(intrinsicDeps.ts, 61, 26))

    // then add one
    return x + 1;
>x : Symbol(x, Decl(intrinsicDeps.ts, 63, 7))

};
type D11 = Intrinsic<typeof withLineComments, [5]>;  // 11
>D11 : Symbol(D11, Decl(intrinsicDeps.ts, 66, 2))
>Intrinsic : Symbol(Intrinsic, Decl(lib.es5.d.ts, --, --))
