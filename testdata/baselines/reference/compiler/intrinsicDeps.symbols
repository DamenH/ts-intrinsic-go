>s : Symbol(s, Decl(intrinsicDeps.ts, 57, 19))
>split : Symbol(String.split, Decl(lib.es5.d.ts, --, --), Decl(lib.es2015.symbol.wellknown.d.ts, --, --))
>map : Symbol(Array.map, Decl(lib.es5.d.ts, --, --))
