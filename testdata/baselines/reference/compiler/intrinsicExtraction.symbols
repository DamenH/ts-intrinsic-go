=== extraction.ts ===
// Multiline function body
const multiline = (n: number) => {
>multiline : Symbol(multiline, Decl(extraction.ts, 1, 5))
>n : Symbol(n, Decl(extraction.ts, 1, 19))

    let x: number = n
>x : Symbol(x, Decl(extraction.ts, 2, 7))
>n : Symbol(n, Decl(extraction.ts, 1, 19))

        + 1;
    let y: number = x
>y : Symbol(y, Decl(extraction.ts, 4, 7))
>x : Symbol(x, Decl(extraction.ts, 2, 7))

        * 2;
    return y;
>y : Symbol(y, Decl(extraction.ts, 4, 7))

};
type EX1 = Intrinsic<typeof multiline, [5]>;  // 12
>EX1 : Symbol(EX1, Decl(extraction.ts, 7, 2))
>Intrinsic : Symbol(Intrinsic, Decl(lib.es5.d.ts, --, --))
>multiline : Symbol(multiline, Decl(extraction.ts, 1, 5))

// Type annotations on parameters and locals
const annotated = (
>annotated : Symbol(annotated, Decl(extraction.ts, 11, 5))

    s: string,
>s : Symbol(s, Decl(extraction.ts, 11, 19))

    n: number,
>n : Symbol(n, Decl(extraction.ts, 12, 14))

    flag: boolean
>flag : Symbol(flag, Decl(extraction.ts, 13, 14))

) => {
    let result: string = s;
>result : Symbol(result, Decl(extraction.ts, 16, 7))
>s : Symbol(s, Decl(extraction.ts, 11, 19))

    let count: number = n;
>count : Symbol(count, Decl(extraction.ts, 17, 7))
>n : Symbol(n, Decl(extraction.ts, 12, 14))

    if (flag) return result + count;
>flag : Symbol(flag, Decl(extraction.ts, 13, 14))
>result : Symbol(result, Decl(extraction.ts, 16, 7))
>count : Symbol(count, Decl(extraction.ts, 17, 7))

    return result;
>result : Symbol(result, Decl(extraction.ts, 16, 7))

};
type EX2 = Intrinsic<typeof annotated, ["x", 3, true]>;  // "x3"
