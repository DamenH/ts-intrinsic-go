>n : Symbol(n, Decl(extraction_errors.ts, 11, 16))

const foo = new Foo();
>foo : Symbol(foo, Decl(extraction_errors.ts, 12, 5))
>Foo : Symbol(Foo, Decl(extraction_errors.ts, 8, 44))

// Function declaration: source extraction requires arrow or function expression
function regularFn(n: number) { return n * 2; }
>regularFn : Symbol(regularFn, Decl(extraction_errors.ts, 12, 22))
>n : Symbol(n, Decl(extraction_errors.ts, 15, 19))
>n : Symbol(n, Decl(extraction_errors.ts, 15, 19))

type ERR3 = Intrinsic<typeof regularFn, [5]>;  // deferred (can't extract source)
