=== extraction_errors.ts ===
// as const in dependency (not extractable, runtime error)
const AS_CONST = "hello" as const;
>AS_CONST : Symbol(AS_CONST, Decl(extraction_errors.ts, 1, 5))
>const : Symbol(const)

const usesAsConst = (s: string) => s + AS_CONST;
>usesAsConst : Symbol(usesAsConst, Decl(extraction_errors.ts, 2, 5))
>s : Symbol(s, Decl(extraction_errors.ts, 2, 21))
>s : Symbol(s, Decl(extraction_errors.ts, 2, 21))
>AS_CONST : Symbol(AS_CONST, Decl(extraction_errors.ts, 1, 5))

type ERR1 = Intrinsic<typeof usesAsConst, ["x"]>;
>ERR1 : Symbol(ERR1, Decl(extraction_errors.ts, 2, 48))
>Intrinsic : Symbol(Intrinsic, Decl(lib.es5.d.ts, --, --))
>usesAsConst : Symbol(usesAsConst, Decl(extraction_errors.ts, 2, 5))

// Function declaration (not const arrow, not extractable as dep)
function helperFn(n: number): number { return n + 1; }
>helperFn : Symbol(helperFn, Decl(extraction_errors.ts, 3, 49))
>n : Symbol(n, Decl(extraction_errors.ts, 6, 18))
>n : Symbol(n, Decl(extraction_errors.ts, 6, 18))

const usesFunc = (n: number) => helperFn(n);
>usesFunc : Symbol(usesFunc, Decl(extraction_errors.ts, 7, 5))
>n : Symbol(n, Decl(extraction_errors.ts, 7, 18))
>helperFn : Symbol(helperFn, Decl(extraction_errors.ts, 3, 49))
>n : Symbol(n, Decl(extraction_errors.ts, 7, 18))

type ERR2 = Intrinsic<typeof usesFunc, [5]>;
>ERR2 : Symbol(ERR2, Decl(extraction_errors.ts, 7, 44))
>Intrinsic : Symbol(Intrinsic, Decl(lib.es5.d.ts, --, --))
>usesFunc : Symbol(usesFunc, Decl(extraction_errors.ts, 7, 5))

// Class method (not an arrow function)
class Foo { bar(n: number) { return n; } }
>Foo : Symbol(Foo, Decl(extraction_errors.ts, 8, 44))
>bar : Symbol(Foo.bar, Decl(extraction_errors.ts, 11, 11))
