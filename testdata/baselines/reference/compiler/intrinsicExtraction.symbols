// Comments inside the function body
const withComments = (n: number) => {
>withComments : Symbol(withComments, Decl(extraction.ts, 60, 5))
>n : Symbol(n, Decl(extraction.ts, 60, 22))

    // line comment
    let x: number = n + 1; /* inline */
>x : Symbol(x, Decl(extraction.ts, 62, 7))
>n : Symbol(n, Decl(extraction.ts, 60, 22))

    /*
       block
    */
    return x * 2;
>x : Symbol(x, Decl(extraction.ts, 62, 7))

};
type EX12 = Intrinsic<typeof withComments, [4]>;  // 10
