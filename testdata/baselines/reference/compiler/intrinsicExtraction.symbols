    let inner = (x: number) => x * 2;
>inner : Symbol(inner, Decl(extraction.ts, 72, 7))
>x : Symbol(x, Decl(extraction.ts, 72, 17))
>x : Symbol(x, Decl(extraction.ts, 72, 17))

    return inner(n) + inner(n + 1);
>inner : Symbol(inner, Decl(extraction.ts, 72, 7))
>n : Symbol(n, Decl(extraction.ts, 71, 15))
>inner : Symbol(inner, Decl(extraction.ts, 72, 7))
>n : Symbol(n, Decl(extraction.ts, 71, 15))

};
type EX13 = Intrinsic<typeof outer, [3]>;  // 6 + 8 = 14
