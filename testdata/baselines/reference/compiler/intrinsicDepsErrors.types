>(n: number) => n * 2 : (n: number) => number
>n : number
>n * 2 : number
>n : number
>2 : 2

    return innerHelper(x);
>innerHelper(x) : number
>innerHelper : (n: number) => number
>x : number

};
type E2 = Intrinsic<typeof outerFn, [5]>;  // 10
>E2 : 10
>outerFn : (x: number) => number

