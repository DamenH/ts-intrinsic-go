// let declaration: not extracted
let mutableHelper = (n: number) => n + 1;
>mutableHelper : (n: number) => number
>(n: number) => n + 1 : (n: number) => number
>n : number
>n + 1 : number
>n : number
>1 : 1

const usesMutable = (x: number) => mutableHelper(x);
>usesMutable : (x: number) => number
>(x: number) => mutableHelper(x) : (x: number) => number
>x : number
>mutableHelper(x) : number
>mutableHelper : (n: number) => number
>x : number

type E1 = Intrinsic<typeof usesMutable, [5]>;
>E1 : any
>usesMutable : (x: number) => number

// Inner function: works via DSL's own let handling
const outerFn = (x: number) => {
>outerFn : (x: number) => number
>(x: number) => {    let innerHelper = (n: number) => n * 2;    return innerHelper(x);} : (x: number) => number
